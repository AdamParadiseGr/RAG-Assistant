# ============================================================
# LLM провайдер: groq | openai | anthropic
# ============================================================
LLM_PROVIDER=groq

# Модель (оставь пустым для значения по умолчанию)
# groq:      llama-3.1-8b-instant  (по умолчанию)
# openai:    gpt-4o-mini           (по умолчанию)
# anthropic: claude-haiku-3-5      (по умолчанию)
LLM_MODEL=llama-3.1-8b-instant

# ============================================================
# Embeddings провайдер: local | openai
# ============================================================
EMBED_PROVIDER=local

# Модель embeddings (оставь пустым для значения по умолчанию)
# local:  sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# openai: text-embedding-3-small
# EMBED_MODEL=

# ============================================================
# API ключи — заполни нужный провайдер
# ============================================================

# Groq (бесплатно: https://console.groq.com)
# Добавь несколько ключей для ротации при rate limit
GROQ_API_KEY_1=gsk_your_first_key_here
GROQ_API_KEY_2=gsk_your_second_key_here
GROQ_API_KEY_3=gsk_your_third_key_here

# OpenAI (если LLM_PROVIDER=openai или EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk_your_key_here

# Anthropic (если LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ============================================================
CHROMA_DB_DIR=./chroma_db
PROMPT_VERSION=v3
